SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URL pública do app no Vercel (sem barra final)
NEXT_PUBLIC_APP_URL=https://YOUR_APP.vercel.app

# URL da ferramenta CorretorPRO (GitHub Pages ou domínio próprio)
NEXT_PUBLIC_TOOL_URL=https://guilhermeassisp27-code.github.io/dev/tool.html

# Token secreto do webhook Hotmart (Hotmart → Ferramentas → Webhooks → seu token)
HOTMART_WEBHOOK_TOKEN=your_hottok_here

# Resend — envio do email de boas-vindas/acesso (https://resend.com)
# O dominio em RESEND_FROM precisa estar VERIFICADO no Resend (DNS: SPF + DKIM),
# senao o Resend so entrega para o email dono da conta (modo teste).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=CorretorPRO <acesso@seudominio.com.br>
RESEND_REPLY_TO=suporte@seudominio.com.br

# Chave da API Anthropic — usada apenas pelas rotas legadas em app/api/ai/*.
# NÃO é necessária para o CorretorPRO (o gerador roda via templates no cliente).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
